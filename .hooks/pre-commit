#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

echo "[1/3] Lint check..."
composer lint
if [ $? -ne 0 ]; then
    echo "Lint failed. Run 'composer lint:fix' to auto-fix."
    exit 1
fi

echo "[2/3] Static analysis..."
composer analyse
if [ $? -ne 0 ]; then
    echo "Static analysis failed."
    exit 1
fi

echo "[3/3] Tests with coverage..."
composer test:coverage
if [ $? -ne 0 ]; then
    echo "Tests failed or coverage below 75%."
    exit 1
fi

echo "All pre-commit checks passed."
